<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="fund_approval_history_list_view" model="ir.ui.view">
    <field name="name">fund.approval_history.list</field>
    <field name="model">fund.approval_history</field>
    <field name="arch" type="xml">
      <list>
        <field name="approver_id"/>
        <field name="date"/>
        <field name="approval_level"/>
        <field name="result"/>
        <field name="comment"/>
        <field name="source_model"/>
      </list>
    </field>
  </record>

  <record id="fund_approval_history_search_view" model="ir.ui.view">
    <field name="name">fund.approval_history.search</field>
    <field name="model">fund.approval_history</field>
    <field name="arch" type="xml">
      <search>
        <field name="approver_id"/>
        <field name="approval_level"/>
        <field name="result"/>
      </search>
    </field>
  </record>

  <record id="action_fund_approval_history" model="ir.actions.act_window">
    <field name="name">Approval History</field>
    <field name="res_model">fund.approval_history</field>
    <field name="view_mode">list</field>
  </record>

</odoo>
