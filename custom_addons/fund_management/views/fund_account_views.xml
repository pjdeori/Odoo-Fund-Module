<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="fund_account_list_view" model="ir.ui.view">
    <field name="name">fund.account.list</field>
    <field name="model">fund.account</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="total_received" optional="show"/>
        <field name="available_unassigned_balance"/>
        <field name="amount_currently_on_hold"/>
        <field name="total_assigned_amount"/>
        <field name="company_id" optional="show"/>
      </list>
    </field>
  </record>

  <record id="fund_account_form_view" model="ir.ui.view">
    <field name="name">fund.account.form</field>
    <field name="model">fund.account</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <group string="Balances">
              <field name="total_received"/>
              <field name="available_unassigned_balance"/>
              <field name="amount_currently_on_hold"/>
              <field name="total_assigned_amount"/>
            </group>
            <group>
              <field name="name"/>
              <field name="company_id"/>
              <field name="currency_id"/>
            </group>
          </group>
          <notebook>
            <page string="Ledger Lines">
              <field name="ledger_line_ids" nolabel="1">
                <list>
                  <field name="date"/>
                  <field name="event_type"/>
                  <field name="amount"/>
                  <field name="reference"/>
                </list>
              </field>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <record id="fund_account_search_view" model="ir.ui.view">
    <field name="name">fund.account.search</field>
    <field name="model">fund.account</field>
    <field name="arch" type="xml">
      <search>
        <field name="name"/>
      </search>
    </field>
  </record>

  <record id="action_fund_account" model="ir.actions.act_window">
    <field name="name">Fund Accounts</field>
    <field name="res_model">fund.account</field>
    <field name="view_mode">list,form</field>
  </record>

</odoo>
