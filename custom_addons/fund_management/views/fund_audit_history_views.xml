<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="fund_audit_history_list_view" model="ir.ui.view">
    <field name="name">fund.audit_history.list</field>
    <field name="model">fund.audit_history</field>
    <field name="arch" type="xml">
      <list>
        <field name="actor_id"/>
        <field name="action"/>
        <field name="date_time"/>
        <field name="previous_state"/>
        <field name="new_state"/>
        <field name="amount"/>
        <field name="source_model"/>
      </list>
    </field>
  </record>

  <record id="fund_audit_history_search_view" model="ir.ui.view">
    <field name="name">fund.audit_history.search</field>
    <field name="model">fund.audit_history</field>
    <field name="arch" type="xml">
      <search>
        <field name="actor_id"/>
        <field name="action"/>
      </search>
    </field>
  </record>

  <record id="action_fund_audit_history" model="ir.actions.act_window">
    <field name="name">Audit History</field>
    <field name="res_model">fund.audit_history</field>
    <field name="view_mode">list</field>
  </record>

</odoo>
