<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="fund_allocation_request_list_view" model="ir.ui.view">
    <field name="name">fund.allocation_request.list</field>
    <field name="model">fund.allocation_request</field>
    <field name="arch" type="xml">
      <list>
        <field name="request_number"/>
        <field name="fund_account_id"/>
        <field name="fund_bucket_id"/>
        <field name="amount" sum="Total"/>
        <field name="state" widget="badge"/>
        <field name="request_date"/>
        <field name="requested_by"/>
      </list>
    </field>
  </record>

  <record id="fund_allocation_request_form_view" model="ir.ui.view">
    <field name="name">fund.allocation_request.form</field>
    <field name="model">fund.allocation_request</field>
    <field name="arch" type="xml">
      <form>
        <header>
          <button name="action_submit" string="Submit" type="object"
                  class="btn-primary" invisible="[('state', 'not in', ('draft',))]"/>
          <button name="action_gm_approve" string="GM Approve" type="object"
                  invisible="[('state', 'not in', ('submitted',))]"/>
          <button name="action_md_approve" string="MD Approve" type="object"
                  class="btn-primary" invisible="[('state', 'not in', ('gm_approval',))]"/>
          <button name="action_reject" string="Reject" type="object"
                  invisible="[('state', 'not in', ('gm_approval', 'md_approval'))]"/>
          <button name="action_cancel" string="Cancel" type="object"
                  invisible="[('state', 'not in', ('draft', 'submitted', 'gm_approval', 'md_approval'))]"/>
        </header>
        <sheet>
          <field name="state" widget="statusbar"
                 statusbar_visible="draft,submitted,gm_approval,md_approval,approved"
                 statusbar_colors='{"rejected":"red","cancelled":"gray"}'/>
          <group>
            <group>
              <field name="request_number"/>
              <field name="request_date"/>
              <field name="requested_by"/>
            </group>
            <group>
              <field name="fund_account_id"/>
              <field name="fund_bucket_id"/>
              <field name="amount" widget="monetary"/>
              <field name="company_id"/>
            </group>
          </group>
          <group>
            <field name="purpose"/>
            <field name="attachment" filename="attachment"/>
          </group>
          <notebook>
            <page string="Approval History">
              <field name="approval_history_ids" nolabel="1">
                <list>
                  <field name="approver_id"/>
                  <field name="date"/>
                  <field name="approval_level"/>
                  <field name="result"/>
                  <field name="comment"/>
                </list>
              </field>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <record id="fund_allocation_request_search_view" model="ir.ui.view">
    <field name="name">fund.allocation_request.search</field>
    <field name="model">fund.allocation_request</field>
    <field name="arch" type="xml">
      <search>
        <field name="request_number"/>
        <field name="fund_account_id"/>
        <field name="fund_bucket_id"/>
        <filter name="my_requests" string="My Requests"
                domain="[('requested_by','=',uid)]"/>
        <filter name="pending_gm" string="Pending GM"
                domain="[('state','=','submitted')]"/>
        <filter name="pending_md" string="Pending MD"
                domain="[('state','=','gm_approval')]"/>
        <group expand="0" string="Group By">
          <filter name="group_by_state" string="State"
                  context="{'group_by': 'state'}"/>
        </group>
      </search>
    </field>
  </record>

  <record id="action_fund_allocation_request" model="ir.actions.act_window">
    <field name="name">Allocation Requests</field>
    <field name="res_model">fund.allocation_request</field>
    <field name="view_mode">list,form</field>
    <field name="context">{'default_requested_by': uid}</field>
  </record>

</odoo>
